# ------------------------------------------------------------
# danoh.com environment variables
# Copy to `.env` and fill in values you need for local dev.
# ------------------------------------------------------------

# --- Required for local dev ------------------------------------
# Flip to "true" to run in local mode (bypasses Supabase auth).
NEXT_PUBLIC_LOCAL_MODE=true

# Your Anthropic API key (falls back if the user hasn't set one
# in the in-app Settings). Get it at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Access gate (optional) ------------------------------------
# If set, visitors must enter this code to use AI features in
# NEXT_PUBLIC_LOCAL_MODE. Leave blank to disable the gate.
ACCESS_CODE=

# --- Database (optional; enables access-code sessions, usage
# tracking, and saved programs). Postgres connection string. ----
DATABASE_URL=

# --- Supabase (required in production / non-local mode) --------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- Stripe (optional; enables paid token top-ups) -------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# --- Replicate (optional; enables AI-generated icons) ----------
REPLICATE_API_TOKEN=

# --- Analytics (optional) --------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- App URL (used for Stripe redirects, etc.) -----------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
